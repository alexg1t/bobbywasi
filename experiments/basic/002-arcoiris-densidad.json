  "science": {
    "principle": "Densidad y Flotación",
    "explanation": "La densidad es la cantidad de masa en un volumen determinado. Los líquidos con mayor densidad se hunden, mientras que los menos densos flotan. La miel es el líquido más denso y se queda en el fondo, mientras que el alcohol es el menos denso y flota en la parte superior. Cada líquido mantiene su posición según su densidad relativa.",
    "concepts": [
      {
        "name": "Densidad",
        "description": "Relación entre la masa y el volumen de una sustancia"
      },
      {
        "name": "Flotación",
        "description": "Capacidad de un objeto o líquido de mantenerse sobre otro más denso"
      },
      {
        "name": "Inmiscibilidad",
        "description": "Propiedad de algunos líquidos de no mezclarse entre sí"
      }
    ],
    "realWorldApplications": [
