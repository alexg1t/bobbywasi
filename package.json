{
  "name": "stem-home-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma educativa de experimentos STEM para niños con seguridad integrada",
  "author": "IBM Bob",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "validate:experiments": "tsx scripts/validate-experiments.ts",
    "db:migrate": "cd apps/web && pnpm prisma migrate dev",
    "db:push": "cd apps/web && pnpm prisma db push",
    "db:studio": "cd apps/web && pnpm prisma studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "turbo": "^1.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0"
}